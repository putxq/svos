# ============================================================
# SVOS — Environment Variables
# نسخ هذا الملف إلى .env وأضف المفاتيح الحقيقية
# ============================================================

# ── الأمان ────────────────────────────────────────────────
SVOS_MASTER_KEY=change-this-to-strong-secret
SVOS_API_KEY=change-this-to-strong-secret

# ── LLM (اختر واحداً) ────────────────────────────────────
LLM_PROVIDER=anthropic

# Anthropic Claude (الموصى به)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (اختياري)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini (اختياري)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# ── البريد الإلكتروني ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com

# ── واتساب / Twilio ───────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── الدفع / Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── الدفع / Moyasar (للسوق السعودي) ──────────────────────
MOYASAR_API_KEY=...
MOYASAR_PUBLISHABLE_KEY=...

# ── قاعدة البيانات ────────────────────────────────────────
# SQLite (افتراضي - يعمل بدون إعداد)
# POSTGRES_DSN=postgresql://user:pass@host:5432/svos

# ── الخادم ───────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production
